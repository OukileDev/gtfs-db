# URL du GTFS
GTFS_URL = 
# Connexion PostgreSQL admin (base 'postgres') pour créer les autres bases
ADMIN_DATABASE_URL = postgresql://user:password@localhost:5432/postgres
# Connexion PostgreSQL vers le registre des versions
REGISTRY_DATABASE_URL = postgresql://user:password@localhost:5432/gtfs_infos

# BunnyCDN Storage (pour l'upload des shapes GeoJSON)
BUNNY_STORAGE_HOSTNAME = storage.bunnycdn.com
BUNNY_STORAGE_ZONE =
BUNNY_API_KEY = 
# Sous-dossier dans la zone de stockage (optionnel, défaut : shapes)
BUNNY_PATH_PREFIX = shapes
